# Dockerfile optimizado para desarrollo/testing local
FROM ubuntu:22.04

# Metadata
LABEL maintainer="dgongut"
LABEL description="DropBot - Telegram file management bot (Local Development)"

# Evitar prompts interactivos durante la instalación
ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /app

# Copiar archivo de configuración de yt-dlp antes de instalar dependencias
# Esto permite que yt-dlp descargue automáticamente los scripts EJS necesarios para YouTube
COPY yt-dlp.conf /etc/yt-dlp.conf

# Instalar dependencias del sistema (incluyendo dependencias para Playwright/Chromium)
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        tzdata \
        ffmpeg \
        unrar \
        wget \
        curl \
        unzip \
        # Dependencias para Playwright/Chromium headless
        libnss3 \
        libnspr4 \
        libatk1.0-0 \
        libatk-bridge2.0-0 \
        libcups2 \
        libdrm2 \
        libdbus-1-3 \
        libxkbcommon0 \
        libatspi2.0-0 \
        libxcomposite1 \
        libxdamage1 \
        libxfixes3 \
        libxrandr2 \
        libgbm1 \
        libasound2 \
        libpango-1.0-0 \
        libcairo2 \
        libxshmfence1 \
        fonts-liberation && \
    # Instalar Deno (requerido por yt-dlp para descargas de YouTube)
    # Deno es el runtime de JavaScript recomendado para resolver desafíos JS de YouTube
    curl -fsSL https://deno.land/install.sh | sh && \
    mv /root/.deno/bin/deno /usr/local/bin/deno && \
    chmod +x /usr/local/bin/deno && \
    # Verificar instalación de Deno
    deno --version && \
    # Limpiar archivos temporales
    rm -rf /root/.deno && \
    apt-get remove -y curl unzip && \
    apt-get autoremove -y && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*

# Copiar código fuente (esto se hace después de instalar deps para aprovechar cache)
COPY . .

# Instalar dependencias de Python
RUN pip3 install --no-cache-dir -r /app/requirements.txt && \
    pip3 install --no-cache-dir bgutil-ytdlp-pot-provider && \
    # Instalar Playwright y Chromium para generación de cookies
    pip3 install --no-cache-dir playwright && \
    playwright install chromium

# Crear directorio para cookies
RUN mkdir -p /app /tmp/cookies_cache

# Copiar entrypoint script
COPY docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

VOLUME /downloads

# Healthcheck (verificar que el proceso Python esté corriendo)
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD pgrep -f "python3 dropbot.py" || exit 1

ENTRYPOINT ["/docker-entrypoint.sh"]